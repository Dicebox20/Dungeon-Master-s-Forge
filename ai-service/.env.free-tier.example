DMF_HOST=127.0.0.1
DMF_PORT=8788
DMF_AI_MODE=openai

# Public Foundry installations originate from many local, LAN, and hosted URLs.
DMF_PUBLIC_FREE_TIER=true
DMF_ALLOWED_ORIGINS=*
DMF_CLIENT_TOKEN=

# Enable only behind a trusted reverse proxy that replaces X-Forwarded-For.
DMF_TRUST_PROXY=true

# Rate limiting is an abuse safeguard. Hosted allowance is measured by provider
# tokens when available, with a deterministic data-size fallback.
DMF_RATE_LIMIT_PER_MINUTE=2
DMF_CLIENT_DAILY_USAGE_LIMIT=0
DMF_CLIENT_MONTHLY_USAGE_LIMIT=500000
DMF_GLOBAL_DAILY_USAGE_LIMIT=10000000
DMF_QUOTA_DATABASE_PATH=./data/free-tier-quota.sqlite
DMF_QUOTA_HASH_SECRET=replace-with-at-least-32-random-characters
DMF_ERROR_REPORTS_ENABLED=true
DMF_ERROR_REPORT_PATH=./data/error-reports.jsonl
DMF_ERROR_REPORT_RETENTION_DAYS=30
DMF_MAX_CONCURRENT_COMPILATIONS=2
DMF_MAX_QUEUED_COMPILATIONS=10
DMF_MAX_REQUEST_CHARS=6000
DMF_MAX_ITEMS_PER_REQUEST=3
DMF_CACHE_TTL_MS=300000
DMF_CACHE_MAX_ENTRIES=500

OPENAI_API_KEY=replace-with-server-side-openai-key
OPENAI_MODEL=gpt-5.4-mini
DMF_ALLOWED_MODELS=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com/v1
DMF_OPENAI_TIMEOUT_MS=90000
DMF_MAX_OUTPUT_TOKENS=12000
